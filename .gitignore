# macOS
.DS_Store

# IDE
*.iml
.idea/
.vscode/

# Build artifacts at the repo root (Flutter has its own .gitignore inside flutter/)
/build/
/.dart_tool/
/.flutter-plugins-dependencies

# Release binaries — should be uploaded to GitHub Releases, not committed
*.aab
*.apk
*.ipa

# Secrets — never commit
flutter/android/key.properties
flutter/android/app/upload-keystore.jks
**/*.keystore
**/*.jks
